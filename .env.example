# Required: your Runway developer key (https://dev.runwayml.com/)
RUNWAYML_API_SECRET=

# Optional: restrict which hostnames external media URLs may resolve to.
# Comma-separated. Recommended for production deploys.
# RUNWAY_ALLOWED_MEDIA_HOSTS=storage.googleapis.com,cdn.example.com

# SQLite database file location (relative to the repo root).
DATABASE_URL=./data/director.db

# Where generated media is stored. Created on demand.
ASSETS_DIR=./data/assets
